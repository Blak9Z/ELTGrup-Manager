# PostgreSQL (Supabase sau local)
# Pentru Supabase foloseste URI-ul "Transaction pooler" pentru runtime:
#
# `connection_limit=1` poate provoca timeout-uri Prisma pe paginile cu query-uri paralele.
# Pentru productie foloseste minim 5 (ideal 10+ daca traficul este ridicat).
DATABASE_URL="postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"

# Pentru migrate/seed foloseste URI-ul "Direct connection":
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="schimba-cu-o-cheie-lunga-si-sigura"
STORAGE_BUCKET="eltgrup-documents"
STORAGE_ENDPOINT="https://s3.example.com"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAP_PROVIDER_TOKEN=""
EFATURA_ENABLED="false"
