generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleKey {
  SUPER_ADMIN
  ADMINISTRATOR
  PROJECT_MANAGER
  SITE_MANAGER
  BACKOFFICE
  WORKER
  ACCOUNTANT
  CLIENT_VIEWER
  SUBCONTRACTOR
}

enum PermissionResource {
  PROJECTS
  TASKS
  TEAMS
  TIME_TRACKING
  MATERIALS
  DOCUMENTS
  INVOICES
  REPORTS
  SETTINGS
  USERS
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  APPROVE
  EXPORT
  MANAGE
}

enum ProjectStatus {
  DRAFT
  PLANNED
  ACTIVE
  BLOCKED
  COMPLETED
  CANCELED
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  INFRASTRUCTURE
  MAINTENANCE
}

enum WorkOrderStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  MEDICAL
  VACATION
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum TimeEntryLiveState {
  STOPPED
  RUNNING
  PAUSED
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  RETURN
  WASTE
  ADJUSTMENT
}

enum MaterialRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ISSUED
  PARTIAL
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  SERVICE
  LOST
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL_PAID
  PAID
  OVERDUE
  CANCELED
}

enum CostType {
  LABOR
  MATERIAL
  SUBCONTRACTOR
  EQUIPMENT
  OTHER
}

enum NotificationType {
  NEW_ASSIGNMENT
  OVERDUE_TASK
  LOW_STOCK
  MISSING_DOCUMENT
  DELAYED_PROJECT
  TIMESHEET_APPROVAL_REQUIRED
  MATERIAL_REQUEST_APPROVAL_REQUIRED
  INVOICE_OVERDUE
  COMPLIANCE_DOCUMENT_EXPIRING
}

enum DocumentCategory {
  CONTRACT
  ANNEX
  OFFER
  INVOICE
  DELIVERY_NOTE
  SITE_REPORT
  PHOTO
  COMPLIANCE
  PERMIT
  HANDOVER
  OTHER
}

enum ClientType {
  COMPANY
  INDIVIDUAL
  PUBLIC_INSTITUTION
  NGO
  OTHER
}

enum SubcontractorApprovalStatus {
  IN_VERIFICARE
  APROBAT
  RESPINS
  SUSPENDAT
}

enum AssignmentStatus {
  PLANIFICAT
  ACTIV
  INTRERUPT
  FINALIZAT
  ANULAT
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  isActive     Boolean   @default(true)
  locale       String    @default("ro")
  avatarUrl    String?
  lastLoginAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  roles                    UserRole[]
  workerProfile            WorkerProfile?
  managerProjects          Project[]             @relation("ProjectManager")
  assignedOrders           WorkOrder[]           @relation("AssignedResponsible")
  comments                 Comment[]
  notifications            Notification[]
  activityLogs             ActivityLog[]
  documents                Document[]            @relation("UploadedBy")
  attendance               Attendance[]
  timeEntries              TimeEntry[]
  equipmentUsage           EquipmentAssignment[]
  costsApproved            CostEntry[]           @relation("CostApprovedBy")
  leadingTeams             Team[]                @relation("TeamLead")
  requestedMaterials       MaterialRequest[]     @relation("RequestedBy")
  approvedMaterialRequests MaterialRequest[]     @relation("MaterialApprovedBy")
  approvedWorkOrders       WorkOrder[]           @relation("WorkOrderApprovedBy")
  approvedTimeEntries      TimeEntry[]           @relation("TimeEntryApprovedBy")
  createdDailyReports      DailySiteReport[]     @relation("ReportCreatedBy")

  accounts Account[]
  sessions Session[]

  @@index([email, isActive])
  @@index([createdAt])
}

model Role {
  id          String   @id @default(cuid())
  key         RoleKey  @unique
  label       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id       String             @id @default(cuid())
  resource PermissionResource
  action   PermissionAction
  label    String

  roles RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Team {
  id         String    @id @default(cuid())
  name       String
  code       String    @unique
  region     String?
  leadUserId String?
  isActive   Boolean   @default(true)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  leadUser   User?           @relation("TeamLead", fields: [leadUserId], references: [id])
  workers    WorkerProfile[]
  workOrders WorkOrder[]
  attendance Attendance[]

  @@index([region])
}

model WorkerProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  teamId           String?
  employeeCode     String    @unique
  positionTitle    String
  hourlyRate       Decimal?  @db.Decimal(10, 2)
  hireDate         DateTime?
  emergencyContact String?
  canApproveTime   Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id])
}

model Client {
  id                 String     @id @default(cuid())
  type               ClientType @default(COMPANY)
  name               String
  cui                String?
  registrationNumber String?
  vatCode            String?
  email              String?
  phone              String?
  billingAddress     String?
  notes              String?
  deletedAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  contacts  ClientContact[]
  projects  Project[]
  documents Document[]
  invoices  Invoice[]

  @@index([name])
  @@index([type, deletedAt])
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  fullName  String
  roleTitle String?
  phone     String?
  email     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Project {
  id              String        @id @default(cuid())
  code            String        @unique
  title           String
  description     String?
  status          ProjectStatus
  type            ProjectType
  siteAddress     String
  siteLatitude    Decimal?      @db.Decimal(10, 7)
  siteLongitude   Decimal?      @db.Decimal(10, 7)
  contractValue   Decimal?      @db.Decimal(14, 2)
  estimatedBudget Decimal?      @db.Decimal(14, 2)
  progressPercent Int           @default(0)
  startDate       DateTime?
  endDate         DateTime?
  managerId       String?
  clientId        String
  internalNotes   String?
  riskIssuesLog   String?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  manager              User?                     @relation("ProjectManager", fields: [managerId], references: [id])
  client               Client                    @relation(fields: [clientId], references: [id])
  phases               ProjectPhase[]
  workOrders           WorkOrder[]
  timeEntries          TimeEntry[]
  materialUsage        ProjectMaterialUsage[]
  materialRequests     MaterialRequest[]
  subcontractors       SubcontractorAssignment[]
  invoices             Invoice[]
  costs                CostEntry[]
  dailyReports         DailySiteReport[]
  documents            Document[]
  equipmentAssignments EquipmentAssignment[]
  stockMovements       StockMovement[]

  @@index([status, managerId])
  @@index([clientId])
  @@index([startDate, endDate])
  @@index([deletedAt, status])
}

model ProjectPhase {
  id        String    @id @default(cuid())
  projectId String
  title     String
  position  Int
  startDate DateTime?
  endDate   DateTime?
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@index([projectId, position])
}

model WorkOrder {
  id                String          @id @default(cuid())
  projectId         String
  phaseId           String?
  title             String
  description       String?
  siteLocation      String?
  responsibleId     String?
  teamId            String?
  startDate         DateTime?
  dueDate           DateTime?
  estimatedHours    Decimal?        @db.Decimal(8, 2)
  actualHours       Decimal?        @db.Decimal(8, 2)
  status            WorkOrderStatus @default(TODO)
  priority          TaskPriority    @default(MEDIUM)
  checklistProgress Int             @default(0)
  dependencyIds     String[]
  isRecurring       Boolean         @default(false)
  recurrenceRule    String?
  approvalRequired  Boolean         @default(false)
  approvedAt        DateTime?
  approvedById      String?
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  project                  Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase                    ProjectPhase?             @relation(fields: [phaseId], references: [id])
  responsible              User?                     @relation("AssignedResponsible", fields: [responsibleId], references: [id])
  approvedBy               User?                     @relation("WorkOrderApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  team                     Team?                     @relation(fields: [teamId], references: [id])
  checklistItems           TaskChecklistItem[]
  timeEntries              TimeEntry[]
  comments                 Comment[]
  materialUsage            ProjectMaterialUsage[]
  dailyReports             DailySiteReport[]
  subcontractorAssignments SubcontractorAssignment[]
  documents                Document[]

  @@index([projectId, status])
  @@index([teamId, startDate])
  @@index([dueDate, priority])
  @@index([deletedAt, dueDate, status])
}

model TaskChecklistItem {
  id          String    @id @default(cuid())
  workOrderId String
  label       String
  isDone      Boolean   @default(false)
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId, isDone])
}

model TimeEntry {
  id                      String             @id @default(cuid())
  userId                  String
  projectId               String
  workOrderId             String?
  startAt                 DateTime
  endAt                   DateTime?
  breakMinutes            Int                @default(0)
  overtimeMinutes         Int                @default(0)
  durationMinutes         Int                @default(0)
  note                    String?
  status                  TimeEntryStatus    @default(DRAFT)
  liveState               TimeEntryLiveState @default(STOPPED)
  pausedAt                DateTime?
  pauseAccumulatedMinutes Int                @default(0)
  gpsLatitude             Decimal?           @db.Decimal(10, 7)
  gpsLongitude            Decimal?           @db.Decimal(10, 7)
  approvedById            String?
  approvedAt              DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workOrder  WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  approvedBy User?      @relation("TimeEntryApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([userId, startAt])
  @@index([projectId, status])
  @@index([userId, liveState, endAt])
  @@index([projectId, endAt])
}

model Attendance {
  id           String           @id @default(cuid())
  userId       String
  teamId       String?
  date         DateTime
  checkInAt    DateTime?
  checkOutAt   DateTime?
  status       AttendanceStatus @default(PRESENT)
  gpsLatitude  Decimal?         @db.Decimal(10, 7)
  gpsLongitude Decimal?         @db.Decimal(10, 7)
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id])

  @@unique([userId, date])
  @@index([date, teamId])
}

model Material {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  category      String?
  unitOfMeasure String
  supplierName  String?
  purchasePrice Decimal?  @db.Decimal(10, 2)
  internalCost  Decimal?  @db.Decimal(10, 2)
  minStockLevel Decimal?  @db.Decimal(10, 2)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stockMovements StockMovement[]
  requests       MaterialRequest[]
  usageLogs      ProjectMaterialUsage[]

  @@index([name])
}

model Warehouse {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  address     String?
  managerName String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stockMovements StockMovement[]
}

model StockMovement {
  id          String            @id @default(cuid())
  materialId  String
  warehouseId String
  projectId   String?
  type        StockMovementType
  quantity    Decimal           @db.Decimal(12, 2)
  unitCost    Decimal?          @db.Decimal(10, 2)
  documentRef String?
  note        String?
  movedAt     DateTime          @default(now())
  createdAt   DateTime          @default(now())

  material  Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([warehouseId, movedAt])
  @@index([materialId, type])
  @@index([materialId, warehouseId, type, documentRef])
}

model MaterialRequest {
  id            String                @id @default(cuid())
  projectId     String
  materialId    String
  requestedById String
  approvedById  String?
  quantity      Decimal               @db.Decimal(12, 2)
  status        MaterialRequestStatus @default(PENDING)
  requestedAt   DateTime              @default(now())
  approvedAt    DateTime?
  note          String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  requestedBy User     @relation("RequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedBy  User?    @relation("MaterialApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([requestedAt])
}

model ProjectMaterialUsage {
  id              String   @id @default(cuid())
  projectId       String
  workOrderId     String?
  materialId      String
  quantityPlanned Decimal? @db.Decimal(12, 2)
  quantityIssued  Decimal? @db.Decimal(12, 2)
  quantityUsed    Decimal  @db.Decimal(12, 2)
  loggedAt        DateTime @default(now())
  note            String?

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  material  Material   @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([projectId, loggedAt])
  @@index([materialId])
}

model Equipment {
  id               String          @id @default(cuid())
  code             String          @unique
  name             String
  serialNumber     String?
  category         String?
  status           EquipmentStatus @default(AVAILABLE)
  maintenanceDueAt DateTime?
  qrCode           String?
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  assignments EquipmentAssignment[]
}

model EquipmentAssignment {
  id             String    @id @default(cuid())
  equipmentId    String
  projectId      String?
  assignedUserId String?
  startAt        DateTime
  endAt          DateTime?
  usageHours     Decimal?  @db.Decimal(8, 2)
  note           String?

  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignedUser User?     @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([equipmentId, startAt])
  @@index([projectId])
}

model Subcontractor {
  id             String                      @id @default(cuid())
  name           String
  cui            String?
  contactName    String?
  email          String?
  phone          String?
  approvalStatus SubcontractorApprovalStatus @default(IN_VERIFICARE)
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  assignments SubcontractorAssignment[]

  @@index([approvalStatus, deletedAt])
}

model SubcontractorAssignment {
  id              String           @id @default(cuid())
  subcontractorId String
  projectId       String
  workOrderId     String?
  contractRef     String?
  startDate       DateTime?
  endDate         DateTime?
  status          AssignmentStatus @default(ACTIV)

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workOrder     WorkOrder?    @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([status, startDate])
}

model Document {
  id           String           @id @default(cuid())
  projectId    String?
  clientId     String?
  workOrderId  String?
  category     DocumentCategory
  title        String
  fileName     String
  mimeType     String?
  storagePath  String
  version      Int              @default(1)
  tags         String[]
  expiresAt    DateTime?
  uploadedById String?
  isPrivate    Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  project    Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client     Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  workOrder  WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  uploadedBy User?      @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([projectId, category])
  @@index([expiresAt])
}

model Invoice {
  id            String        @id @default(cuid())
  projectId     String
  clientId      String
  invoiceNumber String        @unique
  issueDate     DateTime
  dueDate       DateTime
  baseAmount    Decimal       @db.Decimal(14, 2)
  vatRate       Decimal       @db.Decimal(5, 2)
  vatAmount     Decimal       @db.Decimal(14, 2)
  totalAmount   Decimal       @db.Decimal(14, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(14, 2)
  status        InvoiceStatus @default(DRAFT)
  sentAt        DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([status, dueDate])
  @@index([projectId])
}

model CostEntry {
  id           String   @id @default(cuid())
  projectId    String
  type         CostType
  description  String
  amount       Decimal  @db.Decimal(14, 2)
  occurredAt   DateTime
  approvedById String?
  createdAt    DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedBy User?   @relation("CostApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([projectId, type])
  @@index([occurredAt])
}

model DailySiteReport {
  id                    String   @id @default(cuid())
  projectId             String
  workOrderId           String?
  reportDate            DateTime
  weather               String?
  workersCount          Int      @default(0)
  subcontractorsPresent String?
  workCompleted         String
  blockers              String?
  safetyIncidents       String?
  materialsReceived     String?
  equipmentUsed         String?
  signatures            String?
  photos                String[]
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  createdBy User?      @relation("ReportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId, reportDate])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  actionUrl String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model Comment {
  id          String   @id @default(cuid())
  workOrderId String
  userId      String
  content     String
  mentions    String[]
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workOrderId, createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  entityType String
  entityId   String
  action     String
  diff       Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
